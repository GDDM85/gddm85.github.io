---
const { id = '', eyebrow = '', title = '', description = '', className = '' } = Astro.props;
---
<section id={id} class={`py-20 ${className}`.trim()}>
  <div class="space-y-8">
    {(eyebrow || title || description) && (
      <div class="space-y-3">
        {eyebrow && <p class="text-sm uppercase tracking-[0.35em] text-cyan-200/80">{eyebrow}</p>}
        {title && <h2 class="text-3xl font-semibold text-white sm:text-4xl">{title}</h2>}
        {description && <p class="max-w-3xl text-slate-300 leading-8">{description}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
