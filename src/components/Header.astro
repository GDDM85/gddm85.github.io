---
import { navItems, socialLinks } from '../data/siteData';
const githubLink = socialLinks.find((link) => link.label === 'GitHub');
---
<header class="sticky top-0 z-30 border-b border-white/10 bg-slate-950/90 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href="#home" class="inline-flex items-center gap-3 font-semibold tracking-[0.2em] text-cyan-200">
      <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-400/10 text-cyan-200 shadow-sm shadow-cyan-500/10">DM</span>
      <span class="hidden text-sm uppercase tracking-[0.24em] text-slate-200 md:inline">Daniel McDermott</span>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-8 text-sm text-slate-300 md:flex">
      {navItems.map((item) => (
        <a href={`#${item.toLowerCase().replace(' ', '-')}`} class="hover:text-cyan-100">{item}</a>
      ))}
    </nav>

    {githubLink && (
      <a
        href={githubLink.href}
        target="_blank"
        rel="noreferrer"
        class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-slate-950/80 text-slate-100 hover:border-cyan-400/20 hover:text-cyan-100"
        aria-label="GitHub"
      >
        {githubLink.icon}
      </a>
    )}
  </div>
</header>
