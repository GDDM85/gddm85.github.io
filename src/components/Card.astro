---
const { label = '', title = '', description = '', href = '', linkLabel = '', icon = '' } = Astro.props;
---
<div class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-soft transition-colors duration-200 hover:border-cyan-400/20 hover:bg-slate-900/95">
  {icon && <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-500/10 text-cyan-200 text-lg">{icon}</div>}
  {label && <span class="inline-flex rounded-full bg-cyan-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-200">{label}</span>}
  {title && <h3 class="mt-4 text-xl font-semibold text-white">{title}</h3>}
  {description && <p class="mt-4 text-slate-300 leading-7">{description}</p>}
  {href && linkLabel && (
    <a href={href} class="mt-6 inline-flex text-sm font-semibold text-cyan-300 hover:text-cyan-100">{linkLabel}</a>
  )}
</div>
